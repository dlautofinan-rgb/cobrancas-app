<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Cobranças Integrado</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        h1 { color: #d9534f; margin-top: 0; display: flex; align-items: center; gap: 10px; }
        
        .busca-box {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ced4da;
            border-radius: 8px;
            font-size: 15px;
            box-sizing: border-box;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #dee2e6;
        }
        th { background-color: #f8f9fa; color: #495057; font-weight: 600; }
        
        .status-badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }
        .pendente { background-color: #fff3cd; color: #856404; }
        .atrasado { background-color: #f8d7da; color: #721c24; }

        .btn-whats {
            background-color: #25D366;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 13px;
        }
        .btn-whats:hover { background-color: #1ebd58; }
        
        .status-conexao {
            padding: 10px;
            background-color: #e2e8f0;
            border-radius: 6px;
            font-size: 13px;
            margin-bottom: 15px;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>💸 Gestão de Cobranças (Dropbox)</h1>
    <div id="status" class="status-conexao">🔄 Conectando ao Dropbox...</div>

    <input type="text" id="busca" class="busca-box" placeholder="Filtrar por cliente, valor ou status..." onkeyup="filtrarTabela()">

    <table>
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Valor Devido</th>
                <th>Vencimento</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody id="tabela-corpo">
            </tbody>
    </table>
</div>

<script>
    // Configurações de Conectividade e Segurança
    const DROPBOX_TOKEN = "SEU_TOKEN_DE_ACESSO_DO_DROPBOX"; 
    const CAMINHO_ARQUIVO_DROPBOX = "/dados_empresa/cobrancas_criptografadas.txt"; 
    const CHAVE_DESCRIPTOGRAFIA = "SUA_CHAVE_SECRETA_DO_JAVA"; // A chave que o Java usa para criptografar

    async function carregarDadosDoDropbox() {
        const statusDiv = document.getElementById('status');
        try {
            // 1. Descarrega o arquivo criptografado do Dropbox
            const resposta = await fetch("https://content.dropboxapi.com/2/files/download", {
                method: "POST",
                headers: {
                    "Authorization": "Bearer " + DROPBOX_TOKEN,
                    "Dropbox-API-Arg": JSON.stringify({ path: CAMINHO_ARQUIVO_DROPBOX })
                }
            });

            if (!resposta.ok) throw new Error("Erro ao baixar dados do Dropbox.");

            // Obtém o texto encriptado bruto
            const textoCriptografado = await resposta.text();

            // 2. Desencripta o conteúdo usando CryptoJS (exemplo usando AES)
            const bytesDecifrados = CryptoJS.AES.decrypt(textoCriptografado, CHAVE_DESCRIPTOGRAFIA);
            const dadosOriginaisTexto = bytesDecifrados.toString(CryptoJS.enc.Utf8);

            if (!dadosOriginaisTexto) {
                throw new Error("Falha na descriptografia. Verifique a sua chave secreta.");
            }

            // Converte o texto plano de volta para um objeto JSON ou Array
            const devedores = JSON.parse(dadosOriginaisTexto);
            
            statusDiv.innerHTML = "🟢 Dados sincronizados com sucesso!";
            statusDiv.style.backgroundColor = "#d4edda";
            statusDiv.style.color = "#155724";

            renderizarTabela(devedores);

        } catch (erro) {
            console.error(erro);
            statusDiv.innerHTML = "🔴 Erro: " + erro.message;
            statusDiv.style.backgroundColor = "#f8d7da";
            statusDiv.style.color = "#721c24";
        }
    }

    function renderizarTabela(dados) {
        const tabela = document.getElementById('tabela-corpo');
        tabela.innerHTML = "";

        dados.forEach(cliente => {
            const statusClass = cliente.diasAtraso > 0 ? 'atrasado' : 'pendente';
            const statusTexto = cliente.diasAtraso > 0 ? `Atrasado (${cliente.diasAtraso} dias)` : 'A vencer';
            const mensagemWhats = encodeURIComponent(`Olá ${cliente.nome}, identificamos uma pendência no valor de R$ ${cliente.valor} vencida em ${cliente.vencimento}. Como podemos ajudar no acerto?`);

            tabela.innerHTML += `
                <tr>
                    <td><strong>${cliente.nome}</strong></td>
                    <td>R$ ${cliente.valor}</td>
                    <td>${cliente.vencimento}</td>
                    <td><span class="status-badge ${statusClass}">${statusTexto}</span></td>
                    <td>
                        <a href="https://wa.me/55${cliente.contato.replace(/\D/g, '')}?text=${mensagemWhats}" target="_blank" class="btn-whats">
                            💬 Cobrar Whats
                        </a>
                    </td>
                </tr>
            `;
        });
    }

    function filtrarTabela() {
        let input = document.getElementById('busca').value.toLowerCase();
        let linhas = document.getElementById('tabela-corpo').getElementsByTagName('tr');

        for (let i = 0; i < linhas.length; i++) {
            let textoLinha = linhas[i].innerText.toLowerCase();
            linhas[i].style.display = textoLinha.includes(input) ? "" : "none";
        }
    }

    // Inicia a carga dos dados assim que a página abre
    carregarDadosDoDropbox();
</script>

</body>
</html>